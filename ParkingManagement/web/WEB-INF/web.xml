<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <display-name>ParkingManagementSystem</display-name>
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controllers.LoginController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>controllers.LogoutController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>StaffManagementController</servlet-name>
        <servlet-class>controllers.StaffManagementController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StaffManagementController</servlet-name>
        <url-pattern>/admin/staffManagement</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CheckInController</servlet-name>
        <servlet-class>controllers.CheckInController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckInController</servlet-name>
        <url-pattern>/staff/check-in</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CheckOutController</servlet-name>
        <servlet-class>controllers.CheckOutController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckOutController</servlet-name>
        <url-pattern>/staff/check-out</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ParkingSlotController</servlet-name>
        <servlet-class>controllers.ParkingSlotController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ParkingSlotController</servlet-name>
        <url-pattern>/staff/parking-slots</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>PricingController</servlet-name>
        <servlet-class>controllers.PricingController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PricingController</servlet-name>
        <url-pattern>/admin/pricing</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>SubscriptionController</servlet-name>
        <servlet-class>controllers.SubscriptionController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubscriptionController</servlet-name>
        <url-pattern>/staff/subscriptions</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ReportController</servlet-name>
        <servlet-class>controllers.ReportController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportController</servlet-name>
        <url-pattern>/admin/reports</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
